{
  "themes": [
    { "slug": "torah-study", "label": "Torah Study", "blurb": "The supreme value of learning, laboring in, and never abandoning the Torah." },
    { "slug": "tradition-and-transmission", "label": "Chain of Tradition", "blurb": "The unbroken handing down of Torah from Sinai through the generations." },
    { "slug": "humility", "label": "Humility", "blurb": "Lowliness of spirit and modesty; the refusal to grasp at one's own importance." },
    { "slug": "arrogance-and-honor-seeking", "label": "Arrogance & Honor-Seeking", "blurb": "Pride, the chase after fame and greatness, and their self-destroying power." },
    { "slug": "deeds-over-words", "label": "Deeds Over Words", "blurb": "The primacy of action over speech and study — doing more than one says." },
    { "slug": "speech-and-silence", "label": "Speech & Silence", "blurb": "Guarding one's words, the discipline of silence, and the danger of excess talk." },
    { "slug": "fear-of-heaven", "label": "Fear of Heaven", "blurb": "Reverence and awe before God; fear of sin as the root of enduring wisdom." },
    { "slug": "reward-and-punishment", "label": "Reward & Punishment", "blurb": "Divine recompense for deeds — and serving without expectation of reward." },
    { "slug": "divine-judgment", "label": "Judgment & Reckoning", "blurb": "Giving an account before God; the world weighed by the measure of one's deeds." },
    { "slug": "justice-and-courts", "label": "Justice & the Courts", "blurb": "The conduct of judges and witnesses and the fair administration of the law." },
    { "slug": "repentance", "label": "Repentance", "blurb": "Returning to the right path; teshuvah and good deeds as a shield against ruin." },
    { "slug": "friendship-and-companionship", "label": "Friendship & Companions", "blurb": "Acquiring a friend, seeking good company, and the influence of those near us." },
    { "slug": "teacher-and-student", "label": "Teacher & Student", "blurb": "Raising disciples, honoring one's teacher, and the bond of learning together." },
    { "slug": "peace", "label": "Peace", "blurb": "Loving and pursuing peace; the world held up by the pursuit of harmony." },
    { "slug": "truth", "label": "Truth", "blurb": "Truthfulness as one of the pillars on which the world stands." },
    { "slug": "kindness-and-charity", "label": "Kindness & Charity", "blurb": "Acts of loving-kindness, generosity, and the differing dispositions of givers." },
    { "slug": "love-of-others", "label": "Love of Others", "blurb": "Cherishing people's dignity, judging them favorably, and greeting all warmly." },
    { "slug": "anger-and-temperament", "label": "Anger & Temperament", "blurb": "Mastery over anger and the temperaments — being slow to wrath, easy to appease." },
    { "slug": "self-mastery", "label": "Self-Mastery", "blurb": "Subduing the evil inclination and ruling one's own spirit and desires." },
    { "slug": "desire-and-vices", "label": "Envy, Lust & Honor", "blurb": "The cravings — envy, lust, and the hunger for honor — that drive a person from the world." },
    { "slug": "wealth-and-contentment", "label": "Wealth & Contentment", "blurb": "Rejoicing in one's portion; the burdens of property and the meaning of riches." },
    { "slug": "work-and-livelihood", "label": "Work & Livelihood", "blurb": "The dignity of labor and the pairing of Torah with a worldly occupation." },
    { "slug": "caution-toward-power", "label": "Caution Toward Power", "blurb": "Wariness of the ruling authorities — even as one prays for the government's welfare." },
    { "slug": "leadership-and-communal-responsibility", "label": "Communal Responsibility", "blurb": "Not separating from the community and leading the many toward merit." },
    { "slug": "wisdom", "label": "Wisdom", "blurb": "Who is truly wise — learning from every person and knowing the marks of the wise." },
    { "slug": "good-name", "label": "A Good Name", "blurb": "The crown of a good name that surpasses every other crown." },
    { "slug": "mortality-and-this-world", "label": "Mortality & This World", "blurb": "Life as a vestibule before the world to come; remembering one's end." },
    { "slug": "creation-and-purpose", "label": "Creation & Purpose", "blurb": "The world brought forth by divine utterance, fashioned for God's glory." },
    { "slug": "mitzvot-and-caution", "label": "Care in Mitzvot", "blurb": "Treating a light commandment as gravely as a weighty one; one mitzvah drawing another." },
    { "slug": "divine-providence", "label": "Divine Providence", "blurb": "All is foreseen yet freedom is granted; everything given against a pledge." },
    { "slug": "chosenness-of-israel", "label": "Beloved Israel", "blurb": "Humanity made in the divine image and Israel beloved, gifted the Torah." }
